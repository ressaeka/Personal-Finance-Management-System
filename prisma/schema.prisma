generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model users {
  id_user    Int      @id @default(autoincrement())
  username   String   @unique
  email      String   @unique
  password   String
  created_at DateTime @default(now()) @db.Timestamp
  updated_at DateTime @default(now()) @db.Timestamp

  categories category[]
  transaksis transaksi[]
  laporans   laporan[]
}

model category {
  id_category   Int      @id @default(autoincrement())
  id_user       Int
  nama_category String
  tipe          String
  is_deleted    Boolean  @default(false)
  created_at    DateTime @default(now()) @db.Timestamp
  updated_at    DateTime @default(now()) @db.Timestamp
  deleted_at    DateTime? @db.Timestamp

  user      users      @relation(fields: [id_user], references: [id_user])
  transaksis transaksi[]

  @@unique([id_user, nama_category])
}

model transaksi {
  id_transaksi Int      @id @default(autoincrement())
  id_user      Int
  id_category  Int
  jumlah       Decimal  @db.Decimal(12, 2)
  deskripsi    String?  @db.Text
  catatan      String?  @db.Text
  tanggal      DateTime @default(now()) @db.Date
  is_deleted   Boolean  @default(false)
  created_at   DateTime @default(now()) @db.Timestamp
  updated_at   DateTime? @db.Timestamp
  deleted_at   DateTime? @db.Timestamp

  user     users    @relation(fields: [id_user], references: [id_user])
  category category @relation(fields: [id_category], references: [id_category])

  @@index([id_user, created_at])
}

model laporan {
  id_laporan      Int      @id @default(autoincrement())
  id_user         Int
  periode         String
  tanggal_awal    DateTime @db.Date
  tanggal_akhir   DateTime @db.Date
  total_pemasukan Decimal  @default(0) @db.Decimal
  total_pengeluaran Decimal @default(0) @db.Decimal
  saldo           Decimal  @default(0) @db.Decimal
  created_at      DateTime @default(now()) @db.Timestamp
  updated_at      DateTime @default(now()) @db.Timestamp

  user users @relation(fields: [id_user], references: [id_user])

  @@unique([id_user, periode])
  @@index([tanggal_awal, tanggal_akhir])
}

model token_blacklist {
  jti        String   @id
  created_at DateTime @default(now()) @db.Timestamp

  @@index([created_at])
}
